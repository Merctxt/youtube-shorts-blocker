{
  "manifest_version": 3,
  "name": "YouTube Cleaner",
  "version": "1.0.0",
  "description": "Remove Shorts, Explorar e Mais do YouTube para uma experiência mais limpa e focada.",
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["style.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "128": "logo.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Cleaner",
    "default_icon": {
      "128": "logo.png"
    }
  }
}
